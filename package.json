{
  "name": "lumina-neo-web",
  "version": "1.0.2",
  "private": true,
  "description": "Lumina Neo - Unified Cloudflare Pages Project",
  "main": "functions/api/[[path]].ts",
  "scripts": {
    "build": "echo 'Static site with Cloudflare Functions, no build step required'",
    "deploy": "wrangler pages deploy public",
    "dev": "wrangler pages dev public",
    "start": "wrangler pages dev public",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.0",
    "typescript": "^5.0.0",
    "wrangler": "^3.0.0"
  }
}
